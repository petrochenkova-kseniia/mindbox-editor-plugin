{
  "description": "Автообновление плагина при старте сессии",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/auto-update.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
